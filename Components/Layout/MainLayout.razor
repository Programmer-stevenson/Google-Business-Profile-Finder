@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="app-wrapper">
    <nav class="sidebar">
        <div class="sidebar-header">
            <div class="logo-block">
                <div class="logo-img-wrap">
                    <img src="images/plexura-logo.png" alt="Plexura" class="sidebar-logo" />
                </div>
                <div class="logo-text">
                    <h1>LeadHunter</h1>
                    <p>by <span class="plexura-text">Plexura</span></p>
                </div>
            </div>
        </div>

        <div class="sidebar-section">
            <div class="sidebar-label">WORKSPACE</div>
            <div class="sidebar-nav">
                <NavLink href="/" Match="NavLinkMatch.All" class="nav-item">
                    <svg class="nav-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                    <span>Hunt Leads</span>
                </NavLink>
                <NavLink href="/leads" class="nav-item">
                    <svg class="nav-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1"/></svg>
                    <span>Saved Leads</span>
                </NavLink>
            </div>
        </div>

        <div class="sidebar-section">
            <div class="sidebar-label">ANALYTICS</div>
            <div class="sidebar-nav">
                <NavLink href="/stats" class="nav-item">
                    <svg class="nav-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="12" width="4" height="9"/><rect x="10" y="7" width="4" height="14"/><rect x="17" y="3" width="4" height="18"/></svg>
                    <span>Dashboard</span>
                </NavLink>
                <NavLink href="/history" class="nav-item">
                    <svg class="nav-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    <span>Search History</span>
                </NavLink>
            </div>
        </div>

        <div class="sidebar-footer">
            <button class="theme-toggle" @onclick="ToggleTheme">
                @if (isDark)
                {
                    <svg class="toggle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
                    <span>Light Mode</span>
                }
                else
                {
                    <svg class="toggle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
                    <span>Dark Mode</span>
                }
            </button>
            <div class="sidebar-version">v1.0 · plexura.net</div>
        </div>
    </nav>
    <main class="main-content">
        @Body
    </main>
</div>

@code {
    private bool isDark = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var saved = await JS.InvokeAsync<string?>("localStorage.getItem", "theme");
            if (saved == "light")
            {
                isDark = false;
                await JS.InvokeVoidAsync("setTheme", "light");
                StateHasChanged();
            }
        }
    }

    private async Task ToggleTheme()
    {
        isDark = !isDark;
        var theme = isDark ? "dark" : "light";
        await JS.InvokeVoidAsync("setTheme", theme);
        await JS.InvokeVoidAsync("localStorage.setItem", "theme", theme);
    }
}
